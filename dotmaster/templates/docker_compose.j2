# ==============================================================================
# docker-compose.yml — generated by dotmaster
# Start everything:  docker compose up -d
# Stop everything:   docker compose down
# ==============================================================================

name: {{ project_name | lower | replace(" ", "-") }}

services:
{% if include_app_service %}
  # ── Application ─────────────────────────────────────────────────────────────
  app:
    build:
      context: .
      {% if multistage %}target: runtime{% endif %}
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "${APP_PORT:-{{ app_port }}}:{{ app_port }}"
    volumes:
      # Mount source in dev; remove this line for production containers
      - .:/app:cached
    {% if has_postgres or has_mysql or has_mongo or has_redis %}
    depends_on:
      {% if has_postgres %}
      postgres:
        condition: service_healthy
      {% endif %}
      {% if has_mysql %}
      mysql:
        condition: service_healthy
      {% endif %}
      {% if has_mongo %}
      mongodb:
        condition: service_healthy
      {% endif %}
      {% if has_redis %}
      redis:
        condition: service_healthy
      {% endif %}
    {% endif %}
    networks:
      - app_net

{% endif %}
{% if has_postgres %}
  # ── PostgreSQL ───────────────────────────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-{{ project_name | lower | replace("-", "_") | replace(" ", "_") }}_dev}
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-postgres}
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      # Optional: place init SQL scripts here
      # - ./infra/postgres/init.sql:/docker-entrypoint-initdb.d/init.sql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER:-postgres} -d $${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    networks:
      - app_net

{% endif %}
{% if has_mysql %}
  # ── MySQL / MariaDB ──────────────────────────────────────────────────────────
  mysql:
    image: mysql:8-debian
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: ${MYSQL_DATABASE:-{{ project_name | lower | replace("-", "_") | replace(" ", "_") }}_dev}
      MYSQL_USER: ${MYSQL_USER:-mysql}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD:-mysql}
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD:-rootpassword}
    ports:
      - "${MYSQL_PORT:-3306}:3306"
    volumes:
      - mysql_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-uroot", "-p$${MYSQL_ROOT_PASSWORD:-rootpassword}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - app_net

{% endif %}
{% if has_mongo %}
  # ── MongoDB ──────────────────────────────────────────────────────────────────
  mongodb:
    image: mongo:7
    restart: unless-stopped
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_USERNAME:-admin}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_PASSWORD:-password}
      MONGO_INITDB_DATABASE: ${MONGO_DB:-{{ project_name | lower | replace("-", "_") | replace(" ", "_") }}_dev}
    ports:
      - "${MONGO_PORT:-27017}:27017"
    volumes:
      - mongo_data:/data/db
    healthcheck:
      test: ["CMD", "mongosh", "--quiet", "--eval", "db.adminCommand('ping').ok"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
    networks:
      - app_net

{% endif %}
{% if has_redis %}
  # ── Redis ────────────────────────────────────────────────────────────────────
  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: >
      redis-server
      --requirepass ${REDIS_PASSWORD:-}
      --appendonly yes
      --appendfilename appendonly.aof
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - app_net

{% endif %}
# ==============================================================================
# Named volumes — data persists across container restarts
# ==============================================================================
volumes:
{% if has_postgres %}
  postgres_data:
{% endif %}
{% if has_mysql %}
  mysql_data:
{% endif %}
{% if has_mongo %}
  mongo_data:
{% endif %}
{% if has_redis %}
  redis_data:
{% endif %}

networks:
  app_net:
    driver: bridge
