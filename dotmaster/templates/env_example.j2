# ==============================================================================
# .env.example — generated by dotmaster
# Copy this file to .env and fill in real values.
# NEVER commit the real .env to version control!
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="{{ project_name }}"
APP_ENV=development        # development | staging | production
APP_DEBUG=true
APP_PORT={% if has_python %}8000{% else %}3000{% endif %}
APP_SECRET_KEY=change-me-to-a-long-random-string

{% if has_node and framework in ('nextjs',) %}
# ── Next.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_API_URL=http://localhost:8000
{% endif %}

{% if has_python and framework in ('fastapi', 'django', 'flask') %}
# ── Python / ASGI ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
{% endif %}

{% if db_engines %}
# ── Database ──────────────────────────────────────────────────────────────────
{% if 'postgresql' in db_engines %}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/{{ project_name | replace(' ', '_') | lower }}_dev
{% endif %}
{% if 'mysql' in db_engines %}
DATABASE_URL=mysql://mysql:mysql@localhost:3306/{{ project_name | replace(' ', '_') | lower }}_dev
{% endif %}
{% if 'mongodb' in db_engines %}
DATABASE_URL=mongodb://admin:password@localhost:27017/{{ project_name | replace(' ', '_') | lower }}_dev
{% endif %}
{% if 'sqlite' in db_engines %}
DATABASE_URL=sqlite:///./dev.db
{% endif %}
{% if 'redis' in db_engines %}

# ── Redis / Cache ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
{% endif %}
{% endif %}

