# ==============================================================================
# ruff.toml — generated by dotmaster
# https://docs.astral.sh/ruff/configuration/
# ==============================================================================

# Run `ruff check .` to lint, `ruff format .` to format.

# Target Python version
target-version = "py310"
line-length = 88

# Only check these directories
include = ["*.py", "**/*.py"]
exclude = [
    ".git",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
    ".venv",
    "venv",
    "__pycache__",
    "dist",
    "build",
]

# ── Linting ───────────────────────────────────────────────────────────────────
[lint]
select = [
    "E",    # pycodestyle errors
    "W",    # pycodestyle warnings
    "F",    # pyflakes (undefined names, unused imports, …)
    "I",    # isort (import ordering)
    "B",    # flake8-bugbear (likely bugs and design issues)
    "C4",   # flake8-comprehensions (simpler list/dict/set comprehensions)
    "UP",   # pyupgrade (modern Python syntax)
    "N",    # pep8-naming conventions
    "SIM",  # flake8-simplify (simplifiable code)
    "TID",  # flake8-tidy-imports
    "RUF",  # ruff-specific rules
]
ignore = [
    "E501",   # line-length — handled by the formatter
    "B008",   # do not perform function calls in default arguments
    "N999",   # invalid module name (allows names like `my-app`)
]

# Treat these as fixable automatically
fixable = ["I", "UP", "C4"]

[lint.isort]
{% if project_name %}
known-first-party = ["{{ project_name | replace(' ', '_') | replace('-', '_') | lower }}"]
{% endif %}
combine-as-imports = true
force-sort-within-sections = true

[lint.per-file-ignores]
"tests/**" = ["S101"]           # allow assert in tests
"**/migrations/**" = ["ALL"]    # ignore generated migration files

# ── Formatting ────────────────────────────────────────────────────────────────
{% if use_as_formatter %}
[format]
quote-style = "double"
indent-style = "space"
skip-magic-trailing-comma = false
line-ending = "lf"
{% endif %}
