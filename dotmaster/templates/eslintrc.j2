{
  // ESLint configuration — generated by dotmaster
  "root": true,
  "env": {
    "browser": {{ "true" if has_react else "false" }},
    "node": true,
    "es2022": true
  },
  "parser": {{ '"@typescript-eslint/parser"' if has_typescript else '"espree"' }},
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"{% if has_react %},
    "ecmaFeatures": {
      "jsx": true
    }{% endif %}
  },
  "plugins": [
    {% if has_typescript %}"@typescript-eslint"{% if has_react %},{% endif %}{% endif %}
    {% if has_react %}"react", "react-hooks"{% if testing == "jest" %},{% endif %}{% endif %}
    {% if testing == "jest" %}"jest"{% endif %}
  ],
  "extends": [
    "eslint:recommended"{% if has_typescript %},
    "plugin:@typescript-eslint/recommended"{% endif %}{% if has_react %},
    "plugin:react/recommended",
    "plugin:react-hooks/recommended"{% endif %}{% if testing == "jest" %},
    "plugin:jest/recommended"{% endif %}
  ],
  "settings": {
    {% if has_react %}
    "react": {
      "version": "detect"
    }
    {% endif %}
  },
  "rules": {
    // ── Best practices ──────────────────────────────────────────────────────
    "no-console": "warn",
    "no-unused-vars": "warn",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    {% if has_typescript %}
    // TypeScript-specific — these supersede the base rules above
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/explicit-module-boundary-types": "off",
    "@typescript-eslint/no-explicit-any": "warn",
    {% endif %}
    {% if has_react %}
    // React
    "react/prop-types": "off",
    "react/react-in-jsx-scope": "off"
    {% endif %}
  },
  "ignorePatterns": ["dist/", "build/", ".next/", "node_modules/", "coverage/"]
}
