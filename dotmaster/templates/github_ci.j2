# ==============================================================================
# GitHub Actions — CI workflow
# Generated by dotmaster
# ==============================================================================
name: CI

on:
  push:
    branches: [main, master, develop]
  pull_request:
    branches: [main, master, develop]

concurrency:
  {% raw %}group: ${{ github.workflow }}-${{ github.ref }}{% endraw %}

  cancel-in-progress: true

jobs:
{% if has_node %}
  # ── Node.js checks ──────────────────────────────────────────────────────────
  node:
    name: Node.js — Lint & Test
    runs-on: ubuntu-latest
    strategy:
      matrix:
        node-version: [18, 20]
    steps:
      - uses: actions/checkout@v4

      - name: {% raw %}Set up Node ${{ matrix.node-version }}{% endraw %}

        uses: actions/setup-node@v4
        with:
          {% raw %}node-version: ${{ matrix.node-version }}{% endraw %}

          {% if package_manager == 'pnpm' %}cache: pnpm{% elif package_manager == 'yarn' %}cache: yarn{% else %}cache: npm{% endif %}

      {% if package_manager == 'pnpm' %}
      - name: Enable pnpm
        uses: pnpm/action-setup@v3
        with:
          version: latest
      {% endif %}

      - name: Install dependencies
        run: {% if package_manager == 'pnpm' %}pnpm install --frozen-lockfile{% elif package_manager == 'yarn' %}yarn install --frozen-lockfile{% else %}npm ci{% endif %}

      {% if linter == 'eslint' %}
      - name: Lint
        run: {% if package_manager == 'pnpm' %}pnpm{% elif package_manager == 'yarn' %}yarn{% else %}npm{% endif %} run lint
      {% endif %}

      {% if formatter == 'prettier' %}
      - name: Format check
        run: {% if package_manager == 'pnpm' %}pnpm{% elif package_manager == 'yarn' %}yarn{% else %}npm{% endif %} run format:check
      {% endif %}

      {% if testing in ('jest', 'vitest') %}
      - name: Test
        run: {% if package_manager == 'pnpm' %}pnpm{% elif package_manager == 'yarn' %}yarn{% else %}npm{% endif %} test {% if testing == 'jest' %}-- --coverage{% endif %}
      {% endif %}

      {% if framework == 'nextjs' %}
      - name: Build
        run: {% if package_manager == 'pnpm' %}pnpm{% elif package_manager == 'yarn' %}yarn{% else %}npm{% endif %} run build
      {% endif %}

{% endif %}
{% if has_python %}
  # ── Python checks ───────────────────────────────────────────────────────────
  python:
    name: Python — Lint & Test
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ["3.11", "3.12"]
    steps:
      - uses: actions/checkout@v4

      - name: {% raw %}Set up Python ${{ matrix.python-version }}{% endraw %}

        uses: actions/setup-python@v5
        with:
          {% raw %}python-version: ${{ matrix.python-version }}{% endraw %}

      {% if package_manager == 'poetry' %}
      - name: Install Poetry
        uses: snok/install-poetry@v1
        with:
          virtualenvs-create: true
          virtualenvs-in-project: true

      - name: Install dependencies
        run: poetry install --no-interaction

      {% elif package_manager == 'uv' %}
      - name: Install uv
        uses: astral-sh/setup-uv@v3

      - name: Install dependencies
        run: uv sync

      {% else %}
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt -r requirements-dev.txt || pip install -r requirements.txt

      {% endif %}

      {% if linter == 'ruff' %}
      - name: Ruff lint
        run: {% if package_manager == 'poetry' %}poetry run {% elif package_manager == 'uv' %}uv run {% endif %}ruff check .

      {% endif %}
      {% if formatter == 'black' %}
      - name: Black format check
        run: {% if package_manager == 'poetry' %}poetry run {% elif package_manager == 'uv' %}uv run {% endif %}black --check .

      {% endif %}
      {% if testing == 'pytest' %}
      - name: Pytest
        run: {% if package_manager == 'poetry' %}poetry run {% elif package_manager == 'uv' %}uv run {% endif %}pytest --tb=short
      {% endif %}

{% endif %}
{% if has_go %}
  # ── Go checks ───────────────────────────────────────────────────────────────
  go:
    name: Go — Lint & Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
          cache: true

      - name: Vet
        run: go vet ./...

      - name: Test
        run: go test -race -coverprofile=coverage.txt ./...

      - name: golangci-lint
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest

{% endif %}
{% if docker %}
  # ── Docker build ────────────────────────────────────────────────────────────
  docker:
    name: Docker — Build image
    runs-on: ubuntu-latest
    needs: [{% if has_node %}node{% endif %}{% if has_python %}{% if has_node %}, {% endif %}python{% endif %}{% if has_go %}{% if has_node or has_python %}, {% endif %}go{% endif %}]
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build image
        uses: docker/build-push-action@v5
        with:
          context: .
          push: false
          tags: {{ project_name }}:ci
          cache-from: type=gha
          cache-to: type=gha,mode=max
{% endif %}
