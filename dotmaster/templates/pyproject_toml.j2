# ==============================================================================
# pyproject.toml — generated by dotmaster
# ==============================================================================

[build-system]
{% if package_manager == 'poetry' %}
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"
{% else %}
requires = ["hatchling"]
build-backend = "hatchling.build"
{% endif %}

[project]
name = "{{ project_name | replace(' ', '-') | lower }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
license = { text = "MIT" }
requires-python = ">=3.10"
{% if author %}
authors = [{ name = "{{ author }}" }]
{% endif %}
dependencies = [
{% if framework == 'fastapi' %}
    "fastapi>=0.110.0",
    "uvicorn[standard]>=0.29.0",
    "pydantic>=2.6.0",
{% elif framework == 'django' %}
    "django>=5.0",
    "gunicorn>=22.0",
{% elif framework == 'flask' %}
    "flask>=3.0",
    "gunicorn>=22.0",
{% endif %}
]

{% if package_manager == 'poetry' %}
[tool.poetry]
name = "{{ project_name | replace(' ', '-') | lower }}"
version = "0.1.0"
description = "{{ description }}"
authors = ["{{ author }}"]

[tool.poetry.dependencies]
python = "^3.10"
{% if framework == 'fastapi' %}
fastapi = "^0.110.0"
uvicorn = { version = "^0.29.0", extras = ["standard"] }
pydantic = "^2.6.0"
{% elif framework == 'django' %}
django = "^5.0"
gunicorn = "^22.0"
{% elif framework == 'flask' %}
flask = "^3.0"
gunicorn = "^22.0"
{% endif %}

[tool.poetry.group.dev.dependencies]
{% if use_ruff %}
ruff = "*"
{% endif %}
{% if use_black %}
black = "*"
{% endif %}
{% if use_pytest %}
pytest = "*"
pytest-cov = "*"
{% endif %}
{% endif %}

# ── Ruff ──────────────────────────────────────────────────────────────────────
{% if use_ruff %}
[tool.ruff]
line-length = 88
target-version = "py310"

[tool.ruff.lint]
select = [
    "E",    # pycodestyle errors
    "W",    # pycodestyle warnings
    "F",    # pyflakes
    "I",    # isort
    "B",    # flake8-bugbear
    "C4",   # flake8-comprehensions
    "UP",   # pyupgrade
    "N",    # pep8-naming
]
ignore = ["E501"]   # line length handled by formatter

[tool.ruff.lint.isort]
known-first-party = ["{{ project_name | replace(' ', '_') | replace('-', '_') | lower }}"]
{% endif %}

# ── Black ─────────────────────────────────────────────────────────────────────
{% if use_black %}
[tool.black]
line-length = 88
target-version = ["py310", "py311", "py312"]
{% endif %}

# ── Pytest ────────────────────────────────────────────────────────────────────
{% if use_pytest %}
[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-v --tb=short"
{% endif %}
