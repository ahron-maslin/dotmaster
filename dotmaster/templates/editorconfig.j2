# .editorconfig — generated by dotmaster
# https://editorconfig.org
root = true

# ── Defaults for all files ────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

{% if 'python' in languages %}
# ── Python ────────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 88
{% endif %}

{% if 'go' in languages %}
# ── Go ────────────────────────────────────────────────────────────────────────
[*.go]
indent_style = tab
indent_size = 4
{% endif %}

{% if 'rust' in languages %}
# ── Rust ──────────────────────────────────────────────────────────────────────
[*.rs]
indent_size = 4
{% endif %}

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ── JSON / YAML ───────────────────────────────────────────────────────────────
[*.{json,yml,yaml}]
indent_size = 2

# ── Makefiles ─────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
