# ==============================================================================
# GitLab CI — pipeline configuration
# Generated by dotmaster
# ==============================================================================

stages:
  - lint
  - test
{% if docker %}
  - build
{% endif %}
  - notify

default:
  interruptible: true

variables:
  PIP_CACHE_DIR: "$CI_PROJECT_DIR/.cache/pip"
  NODE_MODULES_CACHE: "$CI_PROJECT_DIR/.cache/node_modules"

{% if has_node %}
# ── Node.js ──────────────────────────────────────────────────────────────────
.node_base:
  image: node:20-alpine
  cache:
    key:
      files:
        - {% if package_manager == 'pnpm' %}pnpm-lock.yaml{% elif package_manager == 'yarn' %}yarn.lock{% else %}package-lock.json{% endif %}
    paths:
      - $NODE_MODULES_CACHE
  before_script:
    {% if package_manager == 'pnpm' %}
    - corepack enable && pnpm install --frozen-lockfile
    {% elif package_manager == 'yarn' %}
    - yarn install --frozen-lockfile
    {% else %}
    - npm ci
    {% endif %}

{% if linter == 'eslint' %}
eslint:
  extends: .node_base
  stage: lint
  script:
    - {% if package_manager == 'pnpm' %}pnpm{% elif package_manager == 'yarn' %}yarn{% else %}npm{% endif %} run lint
{% endif %}

{% if formatter == 'prettier' %}
prettier:
  extends: .node_base
  stage: lint
  script:
    - {% if package_manager == 'pnpm' %}pnpm{% elif package_manager == 'yarn' %}yarn{% else %}npm{% endif %} run format:check
{% endif %}

{% if testing in ('jest', 'vitest') %}
{{ testing }}:
  extends: .node_base
  stage: test
  script:
    - {% if package_manager == 'pnpm' %}pnpm{% elif package_manager == 'yarn' %}yarn{% else %}npm{% endif %} test {% if testing == 'jest' %}-- --coverage{% endif %}
  coverage: '/Lines\s*:\s*(\d+\.?\d*)%/'
  artifacts:
    when: always
    reports:
      junit: junit.xml
{% endif %}
{% endif %}

{% if has_python %}
# ── Python ───────────────────────────────────────────────────────────────────
.python_base:
  image: python:3.12-slim
  cache:
    key:
      files:
        - {% if package_manager == 'poetry' %}poetry.lock{% else %}requirements*.txt{% endif %}
    paths:
      - $PIP_CACHE_DIR
  before_script:
    {% if package_manager == 'poetry' %}
    - pip install poetry --quiet
    - poetry install --no-interaction
    {% else %}
    - pip install -r requirements.txt -q
    {% endif %}

{% if linter == 'ruff' %}
ruff:
  extends: .python_base
  stage: lint
  script:
    - {% if package_manager == 'poetry' %}poetry run {% endif %}ruff check .
{% endif %}

{% if formatter == 'black' %}
black:
  extends: .python_base
  stage: lint
  script:
    - {% if package_manager == 'poetry' %}poetry run {% endif %}black --check .
{% endif %}

{% if testing == 'pytest' %}
pytest:
  extends: .python_base
  stage: test
  script:
    - {% if package_manager == 'poetry' %}poetry run {% endif %}pytest --tb=short --junitxml=report.xml
  artifacts:
    when: always
    reports:
      junit: report.xml
{% endif %}
{% endif %}

{% if docker %}
# ── Docker build ─────────────────────────────────────────────────────────────
docker-build:
  stage: build
  image: docker:24-dind
  services:
    - docker:24-dind
  variables:
    DOCKER_TLS_CERTDIR: "/certs"
  script:
    - docker build -t $CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA .
  only:
    - main
    - master
{% endif %}
