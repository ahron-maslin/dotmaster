{
  // Prettier configuration — generated by dotmaster
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "all",
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf"{% if has_typescript %},
  // TypeScript / JSX
  "parser": "typescript"{% endif %}
}
